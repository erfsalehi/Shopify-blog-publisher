# ─── LLM gateway (required) ───────────────────────────────────────────
# All LLM calls route through Google AI Studio's OpenAI-compatible endpoint.
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional per-stage model overrides (defaults shown; sane out of the box).
# Deliberately spread across distinct models — AI Studio's free-tier rate
# limits are per-model (e.g. 20 requests/day for the non-Lite Flash models,
# 500/day for 3.1 Flash-Lite), so giving each stage its own model avoids
# every stage competing for the same daily cap. See README for the reasoning.
# gemini-3.5-flash returned 503 (over capacity) as of 2026-07, so MODEL_DRAFT
# defaults to gemini-2.5-flash instead — worth retrying 3.5 later.
# MODEL_CALENDAR=gemini-3.1-flash-lite-preview
# MODEL_RESEARCH=gemini-3.1-flash-lite-preview
# MODEL_OUTLINE=gemini-3.1-flash-lite
# MODEL_DRAFT=gemini-2.5-flash
# MODEL_SEO=gemini-3.1-flash-lite
# MODEL_QA=gemini-3-flash-preview

# ─── Linear (required to sync the calendar + drafts) ───────────────────
# Personal API key or workspace API key from Linear → Settings → API.
# Must belong to the workspace at https://linear.app/dandr-flooring.
LINEAR_API_KEY=
# Team name or key (e.g. "Content" or "CON") within that workspace.
LINEAR_TEAM=
# Project the calendar/article issues are filed under. Auto-created on first
# run-calendar if it doesn't already exist.
LINEAR_PROJECT=Blog Content Calendar
# Linear workflow states the pipeline moves issues into. Defaults suit a stock
# Linear team (Backlog/Todo/In Progress/Done). Point these at richer states
# (e.g. "Ready to Review") if your team has them. Unknown names fall back by
# state type so an issue is never left stuck in Backlog.
LINEAR_PUBLISHED_STATE=Done
LINEAR_REVIEW_STATE=In Progress
LINEAR_NEEDS_WORK_STATE=Todo
LINEAR_BLOCKED_STATE=Todo

# ─── Shopify (optional; auto-publishes confident articles live) ───────
# When set, articles that pass QA with confidence >= CONFIDENCE_THRESHOLD
# publish live to Shopify automatically; everything else waits in Linear for
# a human. Leave blank to stay Linear-only. Set ENABLE_SHOPIFY_PUBLISH=false
# to keep credentials but pause auto-publishing.
ENABLE_SHOPIFY_PUBLISH=true
# false = create articles in Shopify UNPUBLISHED (hidden) for a human to review
# and publish from Shopify admin; true = auto-publish live. A safe staging mode.
SHOPIFY_PUBLISH_LIVE=true
# Custom app Admin API access token (Settings → Apps and sales channels →
# Develop apps → your app → API credentials). Scopes: write_content,
# read_products (write_files only if images are enabled). Starts with shpat_.
SHOPIFY_ACCESS_TOKEN=
# Permanent *.myshopify.com domain (Settings → Domains), NOT the custom domain.
SHOPIFY_STORE_DOMAIN=
# Numeric blog id or GID to publish under. Blank = the store's first blog.
SHOPIFY_BLOG_ID=
SHOPIFY_API_VERSION=2025-01
# Public storefront domain (e.g. yourstore.com) — in-article links point here,
# not the *.myshopify.com URL. Falls back to SHOPIFY_STORE_DOMAIN if blank.
PUBLIC_DOMAIN=
# Weave the store in as the place to buy (soft draft mentions + closing CTA).
SHOP_PROMO=true

# ─── AI SEO / GEO (Generative Engine Optimization) ────────────────────
# Answer-first content, a visible FAQ section, and JSON-LD (Article + FAQPage)
# structured data so AI answer engines (ChatGPT/Claude/Gemini/AI Overviews)
# can parse and cite the page. On by default.
ENABLE_GEO=true

# ─── Image generation (optional; disabled by default) ─────────────────
# Master switch. When false, image prompts are dropped into the body as bold
# [bracketed] placeholders (see IMAGE_PLACEHOLDERS) to generate yourself (e.g.
# with Shopify AI). Set true AND fill OPENROUTER_API_KEY to auto-generate.
ENABLE_IMAGES=false
# When not generating, insert bold [prompt] placeholders at image spots.
IMAGE_PLACEHOLDERS=true
# OpenRouter, used only for image gen (cheap Gemini image models, fractions
# of a cent/image on token billing — separate from GOOGLE_API_KEY above,
# which has no free image quota). Get a key + add a small credit balance at
# https://openrouter.ai/settings/keys — no subscription, pay-as-you-go.
# Generated images are hosted on Linear's own file storage, not fal.ai.
OPENROUTER_API_KEY=
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-lite-image

# ─── Seed keyword research (optional) ──────────────────────────────────
# If SEED_KEYWORDS is left empty, run-calendar auto-researches seed keywords
# from NICHE via the LLM instead of requiring you to hand-pick them.
NICHE=
# Comma-separated, e.g. SEED_KEYWORDS=hardwood flooring,laminate flooring
# SEED_KEYWORDS=
# Local-SEO slant: biases seed/topic research toward local + commercial intent.
# Set BUSINESS_LOCATION to a city/region/service area to fold it into research.
LOCAL_SEO=true
# BUSINESS_LOCATION=
# The publishing business — so QA treats brand mentions/CTAs as first-party
# and content is written in the business's own voice.
# BUSINESS_NAME=
# BUSINESS_DESCRIPTION=

# ─── SEO / SERP research (optional; falls back to LLM-only research) ───
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── Notifications (optional; digest logged to stdout if unset) ───────
SLACK_WEBHOOK_URL=

# ─── WhatsApp trigger (Meta Cloud API) — optional ─────────────────────
# Trigger the pipeline by messaging your WhatsApp number. Run with
# `blog-pipeline serve` (needs the [whatsapp] extra). Full walkthrough in
# docs/whatsapp-setup.md. Values come from the Meta app dashboard.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# You invent VERIFY_TOKEN (any string); Meta echoes it back to confirm the URL.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Comma-separated E.164 numbers allowed to trigger the pipeline (yours).
WHATSAPP_ALLOWED_NUMBERS=

# ─── Tracing (optional but recommended) ───────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=blog-pipeline

# ─── Data store ───────────────────────────────────────────────────────
# Default is local SQLite. Point at Postgres for deployment, e.g.
# postgresql+psycopg://user:pass@host:5432/dbname
# A bare postgres:// / postgresql:// (e.g. Railway's ${{Postgres.DATABASE_URL}})
# is normalized to the psycopg driver automatically — see docs/railway-deploy.md.
DATABASE_URL=sqlite:///data/pipeline.db

# ─── Pipeline behavior ────────────────────────────────────────────────
# Articles with QA confidence below this land in "Needs Adjustments" in
# Linear instead of "Ready to Review" (0.0-1.0). Everything reaches Linear
# either way — there's no auto-publish, a human always publishes from there.
CONFIDENCE_THRESHOLD=0.75
# Publishing cadence and how far ahead the calendar stays filled.
CADENCE=3x/week: Mon/Wed/Fri
COVERAGE_TARGET_WEEKS=4
# Target article length (words) and SEO rubric pass mark.
WORD_COUNT_TARGET=1500
SEO_MIN_SCORE=85
