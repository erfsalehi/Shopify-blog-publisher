# ─── LLM gateway (required) ───────────────────────────────────────────
# All LLM calls route through OpenRouter (OpenAI-compatible endpoint).
OPENROUTER_API_KEY=

# Optional per-stage model overrides (defaults shown; sane out of the box).
# MODEL_CALENDAR=anthropic/claude-haiku-4.5
# MODEL_RESEARCH=anthropic/claude-haiku-4.5
# MODEL_OUTLINE=anthropic/claude-haiku-4.5
# MODEL_DRAFT=anthropic/claude-sonnet-5
# MODEL_SEO=anthropic/claude-haiku-4.5
# MODEL_QA=anthropic/claude-opus-4.8

# ─── Shopify (required to publish) ────────────────────────────────────
# Custom app Admin API access token (scopes: write_content, write_files, read_products).
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
# Numeric blog id or GID the articles are published under. Leave blank to
# auto-select the store's first blog at runtime.
SHOPIFY_BLOG_ID=
SHOPIFY_API_VERSION=2025-01

# ─── Image generation (optional; stage skipped if unset) ──────────────
FAL_KEY=

# ─── SEO / SERP research (optional; falls back to LLM-only research) ───
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── Notifications (optional; digest/approval logged if unset) ────────
SLACK_WEBHOOK_URL=
# Base URL used to build article preview links in Slack messages.
PREVIEW_BASE_URL=

# ─── Tracing (optional but recommended) ───────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=shopify-blog-pipeline

# ─── Data store ───────────────────────────────────────────────────────
# Default is local SQLite. Point at Postgres for deployment, e.g.
# postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///data/pipeline.db

# ─── Pipeline behavior ────────────────────────────────────────────────
# gated = always pause for human approval; auto = publish unless QA flags.
GATE_MODE=gated
# Articles with QA confidence below this route to human review (0.0-1.0).
CONFIDENCE_THRESHOLD=0.75
# Publishing cadence and how far ahead the calendar stays filled.
CADENCE=3x/week: Mon/Wed/Fri
COVERAGE_TARGET_WEEKS=4
# Target article length (words) and SEO rubric pass mark.
WORD_COUNT_TARGET=1500
SEO_MIN_SCORE=85
